# Copy this file to `.env` and fill in local runner values.
# `.env` is ignored by git; do not commit real tokens.

LINEAR_API_KEY=
LINEAR_PROJECT_SLUG=f26dbad5798d
LINEAR_PROJECT_SLUGS=
LINEAR_ASSIGNEE=me

SYMPHONY_WORKSPACE_ROOT=~/code/sari-workspaces
SOURCE_REPO_URL=https://github.com/teilomillet/sari.git
CODEX_BIN=codex

SYMPHONY_PORT=4001
SYMPHONY_LOGS_ROOT=log

# Sari runtime facade defaults. Entr'acte can keep using the app-server command
# while Sari chooses the backend underneath.
SARI_BACKEND=fake
SARI_OPENCODE_BASE_URL=http://127.0.0.1:41888
SARI_OPENCODE_CONTEXT_LIMIT_TOKENS=8192
SARI_OPENCODE_RESERVED_OUTPUT_TOKENS=512
SARI_CLAUDE_CONTEXT_LIMIT_TOKENS=
SARI_CLAUDE_RESERVED_OUTPUT_TOKENS=1024
SARI_CLAUDE_TURN_TIMEOUT_MS=300000
SARI_APP_SERVER_COMMAND=/Users/teilomillet/Code/sari/scripts/sari_app_server --backend fake
